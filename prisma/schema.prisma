generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id String @id @default(uuid())
  name String
  email String
  passwordHash String
  avatarUrl String?
  bio String?
  createdAt DateTime @default(now())

  recipes Recipe[]
  bookmarks Bookmark[]
  participants ChallengeParticipant[]
}

model Recipe {
  id String @id @default(uuid())
  userId String
  title String
  description String?
  imageUrl String?
  budgetIdr Int
  servingSize Int
  cookTimeMin Int
  isPopular Boolean @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  ingredients Ingredient[]
  steps Step[]
  bookmarks Bookmark[]
  challenges Challenge[]
}

model Ingredient {
  id String @id @default(uuid())
  recipeId String
  name String
  quantity String
  unit String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Step {
  id String @id @default(uuid())
  recipeId String
  stepNumber Int
  instruction String
  imageUrl String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id String @id @default(uuid())
  userId String
  recipeId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId,recipeId])
}

model Challenge {
  id String @id @default(uuid())
  title String
  description String
  recipeId String?
  weekStart DateTime
  weekEnd DateTime

  recipe Recipe? @relation(fields: [recipeId], references: [id])
  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id String @id @default(uuid())
  userId String
  challengeId String
  joinedAt DateTime @default(now())
  submissionUrl String?

  user User @relation(fields: [userId], references: [id])
  challenge Challenge @relation(fields: [challengeId], references: [id])

  @@unique([userId, challengeId])
} 

